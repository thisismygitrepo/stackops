{
  "$schema": "./opencode.schema.json",
  "share": "disabled",
  "autoupdate": false,
  "instructions": [
    "AGENTS.md"
  ],
  "permission": {
    "*": "ask",
    "bash": "allow",
    "edit": "allow",
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow"
    },
    "grep": "allow",
    "glob": "allow",
    "lsp": "allow",
    "skill": "allow",
    "todowrite": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow",
    "task": "allow",
    "external_directory": "allow",
    "codesearch": "allow"
  },
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": false
    },
    "mcp_everything": {
      "type": "local",
      "command": [
        "bunx",
        "@modelcontextprotocol/server-everything"
      ],
      "enabled": false
    }
  }
}
