{
  "mcpServers": {
    "playwright-user-data-dir": {
      "command": "bunx",
      "args": [
        "@playwright/mcp@latest",
        "--executable-path",
        "/absolute/path/to/chrome-or-brave",
        "--user-data-dir",
        "{home}/data/browsers-profiles/mcp/playwright-custom"
      ]
    }
  }
}
