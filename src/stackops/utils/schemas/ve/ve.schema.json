{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StackOps .ve.yaml",
  "description": "Project virtual environment and cloud sync defaults used by StackOps.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "specs": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ve_path": {
          "type": "string",
          "description": "Virtual environment directory path."
        },
        "ipy_profile": {
          "description": "Optional IPython profile name.",
          "type": [
            "string",
            "null"
          ]
        }
      },
      "required": [
        "ve_path"
      ]
    },
    "cloud": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "cloud": {
          "type": "string",
          "description": "Cloud storage identifier or rclone remote name."
        },
        "root": {
          "type": "string",
          "description": "Root directory within the cloud storage."
        },
        "rel2home": {
          "description": "Whether local paths are relative to the home directory.",
          "type": "boolean"
        },
        "pwd": {
          "description": "Optional password used for encryption.",
          "type": [
            "string",
            "null"
          ]
        },
        "key": {
          "description": "Optional encryption key path.",
          "type": [
            "string",
            "null"
          ]
        },
        "encrypt": {
          "description": "Whether cloud sync encrypts transferred files.",
          "type": "boolean"
        },
        "os_specific": {
          "description": "Whether paths should be OS-specific.",
          "type": "boolean"
        },
        "zip": {
          "description": "Whether files should be compressed before upload.",
          "type": "boolean"
        },
        "share": {
          "description": "Whether sharing or public access is enabled.",
          "type": "boolean"
        },
        "overwrite": {
          "description": "Whether existing files may be overwritten.",
          "type": "boolean"
        }
      },
      "required": [
        "cloud",
        "root",
        "rel2home",
        "pwd",
        "key",
        "encrypt",
        "os_specific",
        "zip",
        "share",
        "overwrite"
      ]
    }
  },
  "anyOf": [
    {
      "required": [
        "specs"
      ]
    },
    {
      "required": [
        "cloud"
      ]
    }
  ]
}
