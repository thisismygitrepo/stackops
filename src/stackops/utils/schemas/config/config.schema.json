{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/thisismygitrepo/stackops/schemas/config.schema.json",
  "title": "StackOps User Config Schema",
  "version": "1.0.0",
  "description": "Schema for the StackOps user configuration file at ~/dotfiles/stackops/config/config.json.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional link to the JSON Schema used for this file."
    },
    "version": {
      "type": "string",
      "description": "Config format version.",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "examples": ["1.0.0"]
    },
    "repos": {
      "$ref": "#/definitions/PathList",
      "description": "Repository roots managed by devops update and status commands."
    },
    "rclone_config_name": {
      "type": "string",
      "description": "Default rclone remote/profile name.",
      "minLength": 1
    },
    "email_config_name": {
      "type": "string",
      "description": "Default email profile name used for notifications.",
      "minLength": 1
    },
    "to_email": {
      "type": "string",
      "description": "Default recipient address used for notifications.",
      "format": "email",
      "minLength": 1
    }
  },
  "required": ["version", "repos", "rclone_config_name", "email_config_name", "to_email"],
  "definitions": {
    "PathList": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    }
  }
}
