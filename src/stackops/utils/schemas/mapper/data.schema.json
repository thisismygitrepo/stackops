{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://bytesense.local/schemas/mapper/data.schema.json",
  "title": "StackOps Backup Mapper",
  "type": "object",
  "propertyNames": {
    "type": "string",
    "minLength": 1
  },
  "additionalProperties": {
    "$ref": "#/$defs/group"
  },
  "$defs": {
    "group": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/entry"
      }
    },
    "entry": {
      "type": "object",
      "properties": {
        "path_local": {
          "type": "string",
          "minLength": 1,
          "pattern": ".*\\S.*",
          "description": "Local file or directory path."
        },
        "path_cloud": {
          "type": "string",
          "minLength": 1,
          "pattern": ".*\\S.*",
          "description": "\"^\" lets stackops derive the remote path from path_local."
        },
        "cloud": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1,
          "pattern": ".*\\S.*",
          "description": "Optional rclone cloud config name for this backup entry. Use null to fall back to --cloud or the default cloud."
        },
        "share_url": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1,
          "pattern": ".*\\S.*",
          "description": "Optional public/share URL for the cloud object. Use null when no share URL exists."
        },
        "encrypt": {
          "type": "boolean",
          "description": "Encrypt the backup before upload."
        },
        "zip": {
          "type": "boolean",
          "description": "Compress the item before upload."
        },
        "rel2home": {
          "type": "boolean",
          "description": "Interpret path_local relative to the user's home directory."
        },
        "os": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/os_name"
          },
          "minItems": 1,
          "uniqueItems": true,
          "description": "Explicit YAML list of supported operating systems."
        }
      },
      "required": [
        "path_local",
        "encrypt",
        "zip",
        "rel2home",
        "os"
      ],
      "additionalProperties": false
    },
    "os_name": {
      "type": "string",
      "enum": [
        "linux",
        "darwin",
        "windows"
      ]
    }
  }
}
