{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://bytesense.local/schemas/secrets.schema.json",
  "title": "StackOps Secrets Catalog",
  "version": "0.3.0",
  "description": "Schema for named entries that contain one or more secret records.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional link to the JSON Schema used for this file."
    },
    "version": {
      "type": "string",
      "description": "Schema or config version.",
      "examples": ["0.3"]
    },
    "entries": {
      "type": "array",
      "description": "Named credential entries that contain one or more secrets.",
      "items": {
        "$ref": "#/definitions/entry"
      },
      "minItems": 1
    }
  },
  "required": ["version", "entries"],
  "definitions": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1,
      "pattern": ".*\\S.*"
    },
    "stringList": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/nonEmptyString"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "stringMap": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/definitions/nonEmptyString"
      },
      "additionalProperties": {
        "$ref": "#/definitions/nonEmptyString"
      }
    },
    "rotation": {
      "type": "object",
      "description": "Optional rotation metadata for a secret.",
      "additionalProperties": false,
      "properties": {
        "lastRotated": {
          "type": "string",
          "format": "date",
          "description": "Date the secret was last rotated."
        },
        "rotateEveryDays": {
          "type": "integer",
          "minimum": 1,
          "description": "Recommended maximum age before rotating this secret."
        },
        "owner": {
          "$ref": "#/definitions/nonEmptyString"
        }
      }
    },
    "entry": {
      "type": "object",
      "description": "An account, tenant, profile, application, or service entry containing one or more secrets.",
      "additionalProperties": false,
      "properties": {
        "name": {
          "$ref": "#/definitions/nonEmptyString",
          "description": "Stable name for this entry."
        },
        "tags": {
          "$ref": "#/definitions/stringList",
          "description": "Labels used to group or filter this entry."
        },
        "description": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "url": {
          "$ref": "#/definitions/nonEmptyString",
          "description": "Relevant service, account, or secret management URL."
        },
        "email": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "username": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "profile": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "secrets": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/secret"
          },
          "minItems": 1
        },
        "metadata": {
          "$ref": "#/definitions/stringMap"
        }
      },
      "required": ["name", "secrets"]
    },
    "secret": {
      "type": "object",
      "description": "One logical secret bundle, such as an API key, token, password, or access key pair.",
      "additionalProperties": false,
      "properties": {
        "name": {
          "$ref": "#/definitions/nonEmptyString",
          "description": "Stable name for this secret."
        },
        "tags": {
          "$ref": "#/definitions/stringList",
          "description": "Labels used to group or filter this secret."
        },
        "description": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "scopes": {
          "$ref": "#/definitions/stringList",
          "description": "Application scopes, permission scopes, or environments where the secret applies."
        },
        "keyValues": {
          "$ref": "#/definitions/stringMap",
          "description": "Environment-style key/value fields for this secret."
        },
        "rotation": {
          "$ref": "#/definitions/rotation"
        },
        "metadata": {
          "$ref": "#/definitions/stringMap"
        },
        "notes": {
          "$ref": "#/definitions/nonEmptyString"
        }
      },
      "required": ["tags", "keyValues"]
    }
  }
}
