{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://bytesense.local/schemas/secrets.schema.json",
  "title": "StackOps Secrets Catalog",
  "version": "0.1.0",
  "description": "Schema for application and account scoped secret records.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "description": "Optional link to the JSON Schema used for this file."
    },
    "version": {
      "type": "string",
      "description": "Schema or config version.",
      "examples": ["0.1"]
    },
    "apps": {
      "type": "object",
      "description": "Applications or services that own one or more credential sets.",
      "propertyNames": {
        "$ref": "#/definitions/nonEmptyString"
      },
      "additionalProperties": {
        "$ref": "#/definitions/application"
      },
      "minProperties": 1
    }
  },
  "required": ["version", "apps"],
  "definitions": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1,
      "pattern": ".*\\S.*"
    },
    "stringList": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/nonEmptyString"
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "stringMap": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/definitions/nonEmptyString"
      },
      "additionalProperties": {
        "$ref": "#/definitions/nonEmptyString"
      }
    },
    "scope": {
      "oneOf": [
        {
          "$ref": "#/definitions/nonEmptyString"
        },
        {
          "$ref": "#/definitions/stringList"
        }
      ]
    },
    "rotation": {
      "type": "object",
      "description": "Optional rotation metadata for a secret.",
      "additionalProperties": false,
      "properties": {
        "lastRotated": {
          "type": "string",
          "format": "date",
          "description": "Date the secret was last rotated."
        },
        "rotateEveryDays": {
          "type": "integer",
          "minimum": 1,
          "description": "Recommended maximum age before rotating this secret."
        },
        "owner": {
          "$ref": "#/definitions/nonEmptyString"
        }
      }
    },
    "secret": {
      "type": "object",
      "description": "One logical credential bundle, such as an API key, token, password, or access key pair.",
      "additionalProperties": false,
      "properties": {
        "tag": {
          "$ref": "#/definitions/nonEmptyString",
          "description": "Stable label for this credential bundle."
        },
        "description": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "scope": {
          "$ref": "#/definitions/scope",
          "description": "Application scope, permission scope, or environment where the secret applies."
        },
        "keyValues": {
          "$ref": "#/definitions/stringMap",
          "description": "Environment-style key/value fields for this secret."
        },
        "rotation": {
          "$ref": "#/definitions/rotation"
        },
        "metadata": {
          "$ref": "#/definitions/stringMap"
        },
        "notes": {
          "$ref": "#/definitions/nonEmptyString"
        }
      },
      "required": ["tag", "keyValues"]
    },
    "account": {
      "type": "object",
      "description": "An account, tenant, profile, or environment under an application.",
      "additionalProperties": false,
      "properties": {
        "email": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "username": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "accountId": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "profile": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "url": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "description": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "secrets": {
          "type": "array",
          "items": {
            "$ref": "#/definitions/secret"
          },
          "minItems": 1
        },
        "metadata": {
          "$ref": "#/definitions/stringMap"
        }
      },
      "required": ["secrets"]
    },
    "application": {
      "type": "object",
      "description": "Application or service entry keyed by application name.",
      "additionalProperties": false,
      "properties": {
        "description": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "accounts": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/definitions/nonEmptyString"
          },
          "additionalProperties": {
            "$ref": "#/definitions/account"
          },
          "minProperties": 1
        },
        "metadata": {
          "$ref": "#/definitions/stringMap"
        }
      },
      "required": ["accounts"]
    }
  }
}
