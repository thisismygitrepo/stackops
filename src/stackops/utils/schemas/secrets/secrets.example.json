{
  "$schema": "./secrets.schema.json",
  "version": "0.4",
  "entries": [
    {
      "name": "github-personal",
      "tags": ["github", "personal"],
      "description": "GitHub credentials used by local developer tooling.",
      "url": "https://github.com/octocat",
      "email": "user@example.com",
      "username": "octocat",
      "secrets": [
        {
          "tags": ["personal-access-token"],
          "description": "Token used by git remotes and GitHub CLI automation.",
          "scopes": ["repo", "workflow"],
          "keyValues": {
            "GITHUB_TOKEN": "ghp_replace_me"
          },
          "rotation": {
            "lastRotated": "2026-01-01",
            "rotateEveryDays": 90,
            "owner": "platform"
          }
        }
      ]
    },
    {
      "name": "aws-dev",
      "tags": ["aws", "dev"],
      "description": "AWS credentials grouped by account name.",
      "accountName": "dev",
      "secrets": [
        {
          "tags": ["iam-access-key"],
          "description": "Access key pair for local development only.",
          "scopes": ["development"],
          "keyValues": {
            "AWS_ACCESS_KEY_ID": "AKIA_REPLACE_ME",
            "AWS_SECRET_ACCESS_KEY": "replace_me",
            "AWS_DEFAULT_REGION": "us-east-1"
          }
        }
      ]
    }
  ]
}
