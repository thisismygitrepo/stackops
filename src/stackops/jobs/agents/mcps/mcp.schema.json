{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "https://bytesense.local/schemas/agents/mcps/mcp.schema.json",
  "title": "StackOps MCP Catalog",
  "type": "object",
  "properties": {
    "$schema": {
      "type": "string"
    },
    "mcpServers": {
      "type": "object",
      "propertyNames": {
        "type": "string",
        "minLength": 1,
        "pattern": ".*\\S.*"
      },
      "additionalProperties": {
        "$ref": "#/definitions/serverDefinition"
      }
    }
  },
  "required": [
    "mcpServers"
  ],
  "additionalProperties": false,
  "definitions": {
    "nonEmptyString": {
      "type": "string",
      "minLength": 1,
      "pattern": ".*\\S.*"
    },
    "stringList": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "stringMap": {
      "type": "object",
      "propertyNames": {
        "type": "string"
      },
      "additionalProperties": {
        "type": "string"
      }
    },
    "stdioServer": {
      "type": "object",
      "properties": {
        "command": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "args": {
          "$ref": "#/definitions/stringList"
        },
        "env": {
          "$ref": "#/definitions/stringMap"
        },
        "cwd": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "description": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "enabled": {
          "type": "boolean"
        }
      },
      "required": [
        "command"
      ],
      "additionalProperties": false
    },
    "httpServer": {
      "type": "object",
      "properties": {
        "url": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "headers": {
          "$ref": "#/definitions/stringMap"
        },
        "description": {
          "$ref": "#/definitions/nonEmptyString"
        },
        "enabled": {
          "type": "boolean"
        }
      },
      "required": [
        "url"
      ],
      "additionalProperties": false
    },
    "serverDefinition": {
      "oneOf": [
        {
          "$ref": "#/definitions/stdioServer"
        },
        {
          "$ref": "#/definitions/httpServer"
        }
      ]
    }
  }
}
