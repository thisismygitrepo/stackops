{
    "$schema": "https://bit.ly/cfglayout",
    "version": "0.1",
    "layouts": [
        {
            "layoutName": "g1",
            "layoutTabs": [
                {
                    "command": "ls",
                    "startDir": "$HOME",
                    "tabName": "p51s",
                    "tabWeight": 0
                },
                {
                    "command": "uv run python -c 'import time; time.sleep(10); print(\"hello world\")'",
                    "startDir": "$HOME",
                    "tabName": "hello",
                    "tabWeight": 0
                }
            ]
        }
    ]
}